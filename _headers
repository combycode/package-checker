# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://registry.npmjs.org https://api.npmjs.org https://api.deps.dev https://api.github.com; base-uri 'self'; form-action 'self'
